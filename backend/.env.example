# Copy this file to .env and fill in your values
# NEVER commit .env to git

# JWT Secret — generate a strong random string (e.g. openssl rand -hex 64)
JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_STRING_AT_LEAST_64_CHARS

# Server port
PORT=3001

# Anthropic API key (required for AI data extraction)
# Get yours at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Email for Unpaywall open-access full-text retrieval
# Use your institutional or personal email — Unpaywall requires it by policy
UNPAYWALL_EMAIL=your@email.com
